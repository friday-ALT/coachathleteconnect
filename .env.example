# ==================================
# SUPABASE CONFIGURATION
# ==================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api

# Supabase Project URL (e.g., https://xxxxx.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key (public - safe to use in client)
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (secret - server only, never expose to client!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database Connection String (from Supabase Dashboard > Settings > Database)
# Use "Connection pooling" mode for better performance
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# ==================================
# APPLICATION CONFIGURATION
# ==================================

# Session Secret (generate with: openssl rand -base64 32)
SESSION_SECRET=your-session-secret-here-change-in-production

# Email Configuration (Resend API for transactional emails)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Server Configuration
PORT=5000
NODE_ENV=development

# ==================================
# OPTIONAL: Replit Auth (Legacy)
# ==================================
# Only needed if keeping Replit authentication alongside Supabase
REPLIT_DOMAINS=
REPL_ID=
ISSUER_URL=https://replit.com/oidc
